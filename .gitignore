# Terraform generated plans and state
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfplan
*.tfplan.*
**/tfplan

# Local Terraform state backups
terraform-state-backups/
*terraform-state-backups/*
**/terraform-state-backups/

# Private signing and credential files
*.key
*.pem
cosign/**/*.key
cosign/**/*.pem

# Local Cosign key material
cosign/
**/cosign/

# Generated SBOM artifacts
sbom/
**/sbom/

# Local environment files
.env
.env.*

# Grafana credentials
grafana-monitoring-reader.json
*.json.key

# Python generated files and local virtual environments
__pycache__/
*.py[cod]
.venv/
